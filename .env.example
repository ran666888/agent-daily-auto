# 环境变量模板 — 复制为 .env 后填入你的值
# 所有脚本通过 os.getenv("变量名") 读取

# 项目路径（必填）
PROJECT_DIR=/path/to/your/daily-news-site

# DeepSeek API Key（用于文章内容生成，如使用）
# 从 https://platform.deepseek.com/ 获取
DEEPSEEK_API_KEY=sk-your-key-here

# 每源最大抓取条数（可选，默认6）
NEWS_LIMIT=6

# 数据源白名单（可选，逗号分隔，默认全部）
# 可选值: hn, techcrunch, arxiv, hf, github
# NEWS_SOURCES=hn,techcrunch,arxiv

# Vercel 项目名称（可选，用于自动部署）
# VERCEL_PROJECT=your-project-name
# VERCEL_TOKEN=your-vercel-token

# Cloudflare（可选，用于自动清缓存）
# CF_ZONE_ID=your-zone-id
# CF_EMAIL=your-email@example.com
# CF_API_KEY=your-global-api-key

# GitHub（可选，用于自动推送）
# GITHUB_TOKEN=your-github-token
